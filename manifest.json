<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1">
<meta name="theme-color" content="#16241D">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="TradeBid">
<link rel="manifest" href="/manifest.json">
<link rel="apple-touch-icon" href="/icons/icon-180.png">
<link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png">
<title>TradeBid — Post the Job. Verified Contractors Bid.</title>
<meta name="description" content="TradeBid is the RFQ marketplace for home projects. Homeowners post jobs free; LLC-registered, insured contractors subscribe to bid. No lead fees, no commissions.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><circle cx='50' cy='50' r='46' fill='%230E7C5A'/></svg>">
<style>
  :root{
    --paper:#FAF7F0;
    --card:#FFFFFF;
    --ink:#16241D;
    --steel:#5D685F;
    --line:#E7E1D2;
    --brand:#0E7C5A;        /* verified green — trust, go, primary actions */
    --brand-dark:#0A6247;
    --brand-soft:#E4F2EB;
    --sun:#F2A93B;           /* hard-hat amber — secondary accent, badges */
    --sun-dark:#C98515;
    --coral:#E15A3E;         /* alerts, locked states */
    --radius:14px;
    --disp:'Space Grotesk',system-ui,sans-serif;
    --body:'Inter',system-ui,sans-serif;
    --mono:'IBM Plex Mono',ui-monospace,monospace;
    --shadow:0 10px 30px -14px rgba(22,36,29,.18);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{font-family:var(--body);color:var(--ink);background:var(--paper);line-height:1.6;font-size:16px}
  a{color:var(--brand)}
  img{max-width:100%;display:block}
  .wrap{max-width:1120px;margin:0 auto;padding:0 24px}
  button{font-family:inherit}

  header{position:sticky;top:0;z-index:60;background:rgba(250,247,240,.92);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);padding-top:env(safe-area-inset-top)}
  .nav{display:flex;align-items:center;gap:20px;height:64px;position:relative}
  .logo{font-family:var(--disp);font-weight:700;font-size:22px;color:var(--ink);text-decoration:none;display:flex;align-items:center;gap:9px;cursor:pointer;background:none;border:none}
  .logo .mark{width:26px;height:26px;border-radius:50%;background:var(--brand);position:relative;flex:none}
  .logo .mark::after{content:"";position:absolute;left:7px;top:11px;width:9px;height:5px;border-left:2.5px solid #fff;border-bottom:2.5px solid #fff;transform:rotate(-45deg)}
  .nav-links{display:flex;gap:4px;margin-left:12px}
  .nav-links button{font-family:var(--body);font-weight:600;font-size:15px;background:none;border:none;color:var(--steel);padding:9px 13px;cursor:pointer;border-radius:99px;min-height:44px}
  .nav-links button:hover{background:var(--brand-soft);color:var(--brand-dark)}
  .nav-links button.active{background:var(--ink);color:#fff}
  .nav-right{margin-left:auto;display:flex;align-items:center;gap:10px}
  .who-pill{font-family:var(--mono);font-size:11.5px;letter-spacing:.5px;color:var(--steel);background:#fff;border:1px solid var(--line);padding:6px 12px;border-radius:99px;display:flex;align-items:center;gap:6px}
  .who-pill b{color:var(--ink)}
  .hamburger{display:none;flex-direction:column;justify-content:center;gap:5px;width:44px;height:44px;background:none;border:1.5px solid var(--line);border-radius:10px;cursor:pointer;flex:none}
  .hamburger span{display:block;width:18px;height:2px;background:var(--ink);margin:0 auto;border-radius:2px;transition:transform .15s ease, opacity .15s ease}
  .hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
  .hamburger.open span:nth-child(2){opacity:0}
  .hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}

  .btn{font-family:var(--body);font-weight:700;font-size:15px;display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:12px 22px;min-height:44px;border-radius:99px;cursor:pointer;border:1.5px solid var(--ink);text-decoration:none;background:var(--card);color:var(--ink);transition:transform .05s ease}
  .btn:active{transform:scale(.98)}
  .btn-brand{background:var(--brand);border-color:var(--brand-dark);color:#fff;box-shadow:0 4px 14px -4px rgba(14,124,90,.55)}
  .btn-brand:hover{background:var(--brand-dark)}
  .btn-ink{background:var(--ink);border-color:var(--ink);color:#fff}
  .btn-ghost{background:transparent;border-color:var(--line)}
  .btn-ghost:hover{border-color:var(--ink)}
  .btn-sm{padding:8px 16px;font-size:13.5px}
  .btn-block{width:100%}
  .btn[disabled]{opacity:.55;cursor:not-allowed}

  .view{display:none;animation:fade .18s ease}
  .view.active{display:block}
  @keyframes fade{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
  .eyebrow{font-family:var(--mono);font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--brand-dark);margin-bottom:10px;font-weight:600}
  h1,h2,h3{font-family:var(--disp);line-height:1.08}
  h1{font-size:clamp(38px,5.6vw,62px);font-weight:700;letter-spacing:-.5px}
  h2{font-size:clamp(28px,3.6vw,38px);font-weight:700;letter-spacing:-.3px}
  h3{font-size:20px;font-weight:600}
  .sub{color:var(--steel);max-width:56ch;margin-top:14px;font-size:17px}
  section{padding:60px 0}
  .center{text-align:center;margin-left:auto;margin-right:auto}

  /* ---- ID BADGE — signature element ---- */
  .badge{
    display:inline-flex;align-items:center;gap:8px;background:#fff;border:1.5px solid var(--brand);
    border-radius:99px;padding:6px 14px 6px 6px;box-shadow:var(--shadow);
  }
  .badge .dot{width:26px;height:26px;border-radius:50%;background:var(--brand);display:flex;align-items:center;justify-content:center;flex:none}
  .badge .dot svg{width:14px;height:14px}
  .badge b{font-family:var(--mono);font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--brand-dark)}
  .badge span{font-family:var(--mono);font-size:9.5px;color:var(--steel);display:block}

  .idcard{
    background:var(--ink);color:#fff;border-radius:18px;padding:22px;position:relative;overflow:hidden;
    box-shadow:0 24px 50px -18px rgba(22,36,29,.55);
  }
  .idcard::before{content:"";position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(14,124,90,.5),transparent 70%)}
  .idcard-top{display:flex;justify-content:space-between;align-items:flex-start;position:relative}
  .idcard-corner{background:var(--brand);color:#fff;font-family:var(--mono);font-size:10px;letter-spacing:1.5px;padding:5px 10px;border-radius:6px;display:flex;align-items:center;gap:5px}
  .idcard-name{font-family:var(--disp);font-size:24px;font-weight:700;margin-top:14px;position:relative}
  .idcard-trade{font-family:var(--mono);font-size:12px;color:#9FE3C6;margin-top:2px;position:relative}
  .idcard-row{display:flex;gap:24px;margin-top:18px;padding-top:14px;border-top:1px solid rgba(255,255,255,.15);position:relative}
  .idcard-row div b{display:block;font-family:var(--mono);font-size:9.5px;letter-spacing:1.5px;text-transform:uppercase;color:#9AA6A0;font-weight:500}
  .idcard-row div span{font-weight:600;font-size:14px}

  /* ---- HERO ---- */
  .hero{padding:66px 0 40px}
  .hero-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:52px;align-items:center}
  .hero-actions{display:flex;gap:12px;margin-top:30px;flex-wrap:wrap}
  .trust-row{display:flex;align-items:center;gap:18px;margin-top:26px;flex-wrap:wrap}
  .trust-row .mini{font-family:var(--mono);font-size:12px;color:var(--steel)}

  .trades-strip{display:flex;gap:10px;flex-wrap:wrap;margin-top:36px}
  .trade-pill{display:flex;align-items:center;gap:8px;background:#fff;border:1px solid var(--line);border-radius:99px;padding:8px 14px 8px 8px;font-size:13.5px;font-weight:600;cursor:pointer}
  .trade-pill:hover{border-color:var(--brand)}
  .trade-pill .ic{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-family:var(--mono);font-size:10.5px;font-weight:700;flex:none}

  .lanes{display:grid;grid-template-columns:1fr 1fr;gap:22px;margin-top:30px}
  .lane{background:var(--card);border:1px solid var(--line);border-radius:20px;padding:28px;position:relative;box-shadow:var(--shadow)}
  .lane .tag{position:absolute;top:-13px;left:24px;font-family:var(--mono);font-size:11px;letter-spacing:1.5px;padding:4px 12px;border-radius:99px;color:#fff}
  .lane .tag.free{background:var(--brand)}
  .lane .tag.paid{background:var(--sun-dark)}
  .lane ol{margin:18px 0 22px;list-style:none;counter-reset:step}
  .lane ol li{counter-increment:step;display:flex;gap:12px;padding:11px 0;border-top:1px solid var(--line);font-size:15px}
  .lane ol li:first-child{border-top:none}
  .lane ol li::before{content:counter(step);font-family:var(--mono);font-size:12px;color:#fff;background:var(--ink);width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex:none;margin-top:1px}

  .trust{background:var(--ink);color:#fff;border-radius:28px;margin:0 24px}
  .trust-inner{max-width:1120px;margin:0 auto;padding:56px 40px;display:grid;grid-template-columns:.85fr 1.15fr;gap:44px;align-items:center}
  .trust h2{color:#fff}
  .trust p{color:#B9C2BC;max-width:60ch;margin-top:12px}
  .trust ul{margin-top:18px;list-style:none;display:grid;gap:10px}
  .trust li{font-size:14.5px;display:flex;gap:10px;color:#DDE3DF}
  .trust li b{color:#fff}
  .trust li::before{content:"✓";color:var(--sun);font-weight:700}

  .form-shell{max-width:640px;margin:0 auto}
  .form-shell.wide{max-width:760px}
  .card-form{background:var(--card);border:1px solid var(--line);border-radius:20px;padding:30px;box-shadow:var(--shadow);margin-top:22px}
  fieldset{border:none;margin-bottom:24px}
  legend{font-family:var(--disp);font-size:18px;font-weight:700;margin-bottom:2px}
  .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  .grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px}
  label{display:block;font-family:var(--mono);font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--steel);margin:14px 0 5px;font-weight:500}
  input,select,textarea{width:100%;font-family:var(--body);font-size:16px;padding:12px 13px;border:1.5px solid var(--line);border-radius:10px;background:#FCFBF8;color:var(--ink);min-height:44px}
  input:focus,select:focus,textarea:focus{outline:2px solid var(--brand);outline-offset:1px;border-color:var(--brand)}
  textarea{min-height:110px;resize:vertical}
  .chips{display:flex;flex-wrap:wrap;gap:8px;margin-top:6px}
  .chip{font-family:var(--body);font-weight:600;font-size:13px;padding:8px 14px;border:1.5px solid var(--line);border-radius:99px;background:#fff;cursor:pointer;user-select:none}
  .chip.on{border-color:var(--brand);background:var(--brand-soft);color:var(--brand-dark)}
  .upload{border:2px dashed var(--line);border-radius:14px;padding:20px;text-align:center;color:var(--steel);font-size:14px;cursor:pointer;background:#FCFBF8;display:block}
  .upload:hover{border-color:var(--brand);color:var(--brand-dark)}
  .upload input{display:none}
  .form-foot{display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--line);padding-top:20px;gap:16px;flex-wrap:wrap;margin-top:6px}
  .form-foot p{font-size:12.5px;color:var(--steel);max-width:42ch}
  .msg{border-radius:12px;padding:14px 16px;font-size:14px;margin-top:16px;display:none}
  .msg.show{display:block}
  .msg.ok{background:var(--brand-soft);border:1px solid var(--brand);color:var(--brand-dark)}
  .msg.err{background:#FCEAE6;border:1px solid var(--coral);color:#B7402A}
  .helper{font-size:12.5px;color:var(--steel);margin-top:4px}

  .status-pill{font-family:var(--mono);font-size:11.5px;letter-spacing:1px;text-transform:uppercase;padding:5px 12px;border-radius:99px;display:inline-flex;align-items:center;gap:6px;font-weight:600}
  .status-pending{background:#FDF2DE;color:var(--sun-dark)}
  .status-verified{background:var(--brand-soft);color:var(--brand-dark)}
  .status-rejected{background:#FCEAE6;color:#B7402A}

  .board-bar{display:flex;justify-content:space-between;align-items:end;gap:18px;flex-wrap:wrap;margin-bottom:24px}
  .filters{display:flex;gap:8px;flex-wrap:wrap}
  .board{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:20px}
  .job{background:var(--card);border:1px solid var(--line);border-radius:18px;overflow:hidden;position:relative;display:flex;flex-direction:column;box-shadow:var(--shadow)}
  .job-head{display:flex;justify-content:space-between;align-items:center;padding:14px 18px;border-bottom:1px solid var(--line)}
  .job-head .rfqid{font-family:var(--mono);font-size:11px;color:var(--steel)}
  .job-head .count{font-family:var(--mono);font-size:11px;background:var(--brand-soft);color:var(--brand-dark);padding:3px 9px;border-radius:99px;font-weight:600}
  .job-body{padding:18px;flex:1;display:flex;flex-direction:column}
  .job-title{font-family:var(--disp);font-size:19px;font-weight:700}
  .job-meta{display:grid;grid-template-columns:1fr 1fr;gap:8px 16px;margin:14px 0;font-size:13.5px}
  .job-meta div b{display:block;font-family:var(--mono);font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--steel);font-weight:500}
  .job-foot{display:flex;justify-content:space-between;align-items:center;margin-top:auto;padding-top:14px;border-top:1px dashed var(--line)}
  .locked .lockable{filter:blur(5px);user-select:none;pointer-events:none}
  .lock-overlay{position:absolute;inset:0;top:53px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;background:linear-gradient(rgba(250,247,240,.2),rgba(250,247,240,.93));text-align:center;padding:20px}
  .lock-overlay p{font-family:var(--mono);font-size:12px;color:var(--ink);max-width:28ch}

  .pros{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:20px;margin-top:26px}
  .pro{background:var(--card);border:1px solid var(--line);border-radius:18px;overflow:hidden;box-shadow:var(--shadow)}
  .pro-hero{height:96px;position:relative}
  .pro-hero .badge{position:absolute;right:12px;bottom:-18px;transform:scale(.88);transform-origin:right bottom}
  .pro-body{padding:18px}
  .pro-name{font-family:var(--disp);font-size:19px;font-weight:700;margin-top:6px}
  .pro-trade{font-family:var(--mono);font-size:11.5px;color:var(--brand-dark);letter-spacing:.5px;margin-bottom:8px}
  .pro-stats{display:flex;gap:14px;font-size:12.5px;color:var(--steel);border-top:1px solid var(--line);padding-top:10px;margin-top:10px}
  .pro-stats b{color:var(--ink);font-family:var(--mono)}

  .plans{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:34px}
  .plan{background:var(--card);border:1px solid var(--line);border-radius:20px;padding:28px;position:relative;display:flex;flex-direction:column;box-shadow:var(--shadow)}
  .plan.hot{border:2px solid var(--brand)}
  .plan .flag{position:absolute;top:-14px;left:24px;background:var(--brand);color:#fff;font-family:var(--mono);font-size:11px;letter-spacing:1.5px;padding:4px 12px;border-radius:99px}
  .price{font-family:var(--disp);font-size:46px;font-weight:700;line-height:1;margin:12px 0 2px}
  .price sub{font-size:15px;font-family:var(--mono);color:var(--steel);font-weight:400}
  .plan ul{list-style:none;margin:18px 0 22px;flex:1;display:grid;gap:9px}
  .plan li{font-size:14px;display:flex;gap:9px}
  .plan li::before{content:"✓";color:var(--brand);font-weight:700}

  .queue-item{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:20px;margin-top:14px;box-shadow:var(--shadow)}
  .queue-head{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap}
  .queue-meta{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px 20px;margin:14px 0;font-size:13.5px}
  .queue-meta div b{display:block;font-family:var(--mono);font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--steel);font-weight:500}
  .queue-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px;border-top:1px solid var(--line);padding-top:14px}
  .queue-empty{text-align:center;padding:60px 20px;color:var(--steel)}

  .page{max-width:720px;margin:0 auto}
  .faq-item{background:var(--card);border:1px solid var(--line);border-radius:14px;margin-top:12px;overflow:hidden}
  .faq-item summary{cursor:pointer;padding:16px 18px;font-family:var(--disp);font-size:17px;font-weight:600;list-style:none;display:flex;justify-content:space-between;gap:12px}
  .faq-item summary::after{content:"+";color:var(--brand);font-size:20px;font-family:var(--mono)}
  .faq-item[open] summary::after{content:"–"}
  .faq-item div{padding:0 18px 16px;color:var(--steel);font-size:14.5px;border-top:1px solid var(--line);padding-top:12px}
  .legal{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:30px;margin-top:22px}
  .legal h3{margin:20px 0 6px}
  .legal h3:first-child{margin-top:0}
  .legal p,.legal li{font-size:14px;color:var(--steel);margin-bottom:8px}
  .legal ul{margin-left:20px}
  .legal .updated{font-family:var(--mono);font-size:11px;letter-spacing:1px;color:var(--brand-dark);margin-bottom:14px;text-transform:uppercase}

  .authbox{max-width:420px;margin:60px auto 0}
  .swap{text-align:center;margin-top:18px;font-size:14px;color:var(--steel)}
  .swap button{background:none;border:none;color:var(--brand);font-weight:600;cursor:pointer;font-size:14px}

  footer{background:var(--ink);color:#9AA6A0;padding:48px 0 calc(26px + env(safe-area-inset-bottom));font-size:13.5px;margin-top:50px}
  .footer-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:32px}
  footer .logo{color:#fff;margin-bottom:10px}
  footer .logo .mark{background:var(--brand)}
  .foot-blurb{max-width:34ch;font-size:13px;line-height:1.6}
  .foot-col{display:flex;flex-direction:column;gap:8px}
  .foot-col b{font-family:var(--mono);font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:#fff;margin-bottom:4px}
  footer a{color:#9AA6A0;text-decoration:none;cursor:pointer}
  footer a:hover{color:#fff}
  .foot-base{display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;border-top:1px solid #2A362F;margin-top:34px;padding-top:18px}

  @media (max-width:860px){
    .hero-grid,.lanes,.trust-inner,.footer-grid{grid-template-columns:1fr}
    .plans{grid-template-columns:1fr}
    .grid-2,.grid-3{grid-template-columns:1fr}
    .trust{margin:0 12px;border-radius:20px}
    .trust-inner{padding:36px 22px}
  }

  @media (max-width:700px){
    .hamburger{display:flex}
    .nav{height:58px;gap:12px}
    .nav-links{
      display:none;position:absolute;top:calc(100% + 1px);left:0;right:0;
      background:var(--paper);border-bottom:1px solid var(--line);
      flex-direction:column;gap:2px;padding:10px 16px 16px;margin-left:0;
      box-shadow:0 12px 24px -12px rgba(22,36,29,.25);
    }
    .nav-links.open{display:flex}
    .nav-links button{width:100%;text-align:left;padding:12px 14px}
    .logo{font-size:19px}
    .nav-right{gap:6px}
    .nav-right .btn-sm{padding:8px 12px;font-size:12.5px}
    .who-pill{display:none}
    section{padding:42px 0}
    .hero{padding:34px 0 28px}
    .hero-actions .btn,.form-foot .btn{width:100%}
    .idcard{margin-top:6px}
    .trades-strip{gap:8px}
    .board,.pros{grid-template-columns:1fr}
    .job-meta,.queue-meta{grid-template-columns:1fr 1fr}
    .card-form{padding:22px 18px}
    .authbox{margin-top:30px}
  }

  @media (max-width:420px){
    h1{font-size:34px}
    .price{font-size:38px}
    .job-meta,.queue-meta{grid-template-columns:1fr}
    .wrap{padding:0 16px}
  }
  @media (prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}}
</style>
</head>
<body>

<header>
  <div class="wrap nav">
    <button class="logo" onclick="go('home')"><span class="mark"></span>TradeBid</button>
    <nav class="nav-links" id="navLinks" aria-label="Main">
      <button data-v="home" class="active" onclick="go('home')">Home</button>
      <button data-v="post" onclick="go('post')">Post a Job</button>
      <button data-v="board" onclick="go('board')">Find Work</button>
      <button data-v="pros" onclick="go('pros')">Contractors</button>
      <button data-v="pricing" onclick="go('pricing')">Pricing</button>
    </nav>
    <div class="nav-right" id="navRight"></div>
    <button class="hamburger" id="hamburger" aria-label="Menu" aria-expanded="false" onclick="toggleMenu()">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<main id="view-home" class="view active">
  <section class="hero">
    <div class="wrap hero-grid">
      <div>
        <p class="eyebrow">RFQ Marketplace · Residential Trades</p>
        <h1>Post the job.<br>Verified pros bid.</h1>
        <p class="sub">Submit a Request for Quote in minutes — free, always. LLC-registered, insured contractors subscribe to browse open jobs and send competing bids. You pick the pro; we've already checked the paperwork.</p>
        <div class="hero-actions">
          <a class="btn btn-brand" onclick="go('post')">Post a Free RFQ</a>
          <a class="btn btn-ghost" onclick="go('board')">Browse Open Jobs</a>
        </div>
        <div class="trust-row">
          <div class="badge"><span class="dot"><svg viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg></span><b>LLC + Insurance Verified</b></div>
          <span class="mini">Every contractor, every time — checked against the state business registry.</span>
        </div>
        <div class="trades-strip" id="tradeStrip"></div>
      </div>

      <div class="idcard">
        <div class="idcard-top">
          <div>
            <div class="idcard-corner"><svg width="10" height="10" viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>VERIFIED PRO</div>
            <div class="idcard-name">Ridgeline Roofing LLC</div>
            <div class="idcard-trade">ROOFING · KINGSPORT, TN</div>
          </div>
        </div>
        <div class="idcard-row">
          <div><b>Entity</b><span>Active LLC</span></div>
          <div><b>Insurance</b><span>Current COI</span></div>
          <div><b>Jobs won</b><span>41</span></div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <p class="eyebrow">How it works</p>
      <h2>Two sides of the same job site</h2>
      <div class="lanes">
        <div class="lane">
          <span class="tag free">FREE, ALWAYS</span>
          <p style="font-family:var(--mono);font-size:12px;letter-spacing:1.5px;color:var(--steel);text-transform:uppercase;margin-top:4px">For Homeowners</p>
          <h3 style="margin-top:6px">Get competing quotes without the phone tag</h3>
          <ol>
            <li>Fill out one RFQ — scope, photos, budget range, timeline.</li>
            <li>Verified contractors in your area review it and bid.</li>
            <li>Compare bids and each contractor's track record.</li>
            <li>Hire directly. No middleman markup, no fee to you.</li>
          </ol>
          <a class="btn btn-brand" onclick="go('post')">Post a Job</a>
        </div>
        <div class="lane">
          <span class="tag paid">SUBSCRIPTION</span>
          <p style="font-family:var(--mono);font-size:12px;letter-spacing:1.5px;color:var(--steel);text-transform:uppercase;margin-top:4px">For Contractors</p>
          <h3 style="margin-top:6px">A steady board of real jobs — not sold leads</h3>
          <ol>
            <li>Verify once: LLC registration + certificate of insurance.</li>
            <li>Subscribe to unlock the board for your trades and radius.</li>
            <li>Bid unlimited jobs. No per-lead fees, ever.</li>
            <li>Win work and build a public track record that wins the next one.</li>
          </ol>
          <a class="btn btn-ink" onclick="go('signup-contractor')">Get Verified</a>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="trust">
      <div class="trust-inner">
        <div class="idcard" style="transform:rotate(-3deg)">
          <div class="idcard-corner" style="width:fit-content"><svg width="10" height="10" viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>VERIFIED PRO</div>
          <div class="idcard-name" style="margin-top:12px">Your Business LLC</div>
          <div class="idcard-trade">STATUS: ACTIVE · COI CURRENT</div>
        </div>
        <div>
          <p class="eyebrow" style="color:#9FE3C6">The paperwork rule</p>
          <h2>No LLC, no insurance, no listing.</h2>
          <p>Anyone can print business cards. TradeBid contractors clear a real bar before they can see a single job. Every applicant is checked by a real reviewer against their state's official business registry, and every Certificate of Insurance is opened and read — not just uploaded.</p>
          <ul>
            <li><b>Entity check</b> — active LLC or corporation confirmed against the Secretary of State record</li>
            <li><b>Insurance on file</b> — current general liability COI, expiration tracked</li>
            <li><b>Re-verification</b> — required at every policy renewal</li>
            <li><b>Automatic pause</b> — listing suspended immediately if coverage lapses</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</main>

<main id="view-post" class="view">
  <section>
    <div class="wrap form-shell wide">
      <p class="eyebrow">Request for Quote · Free for homeowners</p>
      <h2>Tell contractors what you need built</h2>
      <p class="sub">The more specific your RFQ, the sharper the bids. Your street address is never shown — contractors see city and ZIP until you accept a bid.</p>

      <div id="postGate"></div>

      <form class="card-form" id="rfqForm" onsubmit="return submitRFQ(event)" style="display:none">
        <fieldset>
          <legend>The Project</legend>
          <label for="ptitle">Project title</label>
          <input id="ptitle" required minlength="5" maxlength="160" placeholder="e.g. Replace 28 squares of architectural shingle roofing">
          <label>Trade category</label>
          <div class="chips" id="tradeChips"></div>
          <label for="pdesc">Scope of work</label>
          <textarea id="pdesc" required minlength="20" maxlength="4000" placeholder="Describe the work, materials you prefer, known issues, access notes…"></textarea>
        </fieldset>

        <fieldset>
          <legend>Budget &amp; Timeline</legend>
          <div class="grid-3">
            <div><label for="bmin">Budget min ($)</label><input id="bmin" type="number" inputmode="numeric" min="0" placeholder="5,000"></div>
            <div><label for="bmax">Budget max ($)</label><input id="bmax" type="number" inputmode="numeric" min="0" placeholder="8,500"></div>
            <div><label for="tline">Start timeline</label>
              <select id="tline">
                <option>ASAP / Emergency</option>
                <option selected>Within 30 days</option>
                <option>Within 60 days</option>
                <option>Flexible / planning</option>
              </select>
            </div>
          </div>
        </fieldset>

        <fieldset>
          <legend>Location</legend>
          <div class="grid-2">
            <div><label for="city">City</label><input id="city" required placeholder="Blountville"></div>
            <div><label for="zip">ZIP code</label><input id="zip" required pattern="\d{5}(-\d{4})?" inputmode="numeric" autocomplete="postal-code" placeholder="37617"></div>
          </div>
        </fieldset>

        <div class="form-foot">
          <p>Bids are estimates until a contractor performs a site visit. Posting is free; TradeBid never charges homeowners.</p>
          <button class="btn btn-brand" type="submit" id="rfqSubmitBtn">Publish RFQ</button>
        </div>
        <div class="msg" id="rfqMsg"></div>
      </form>
    </div>
  </section>
</main>

<main id="view-board" class="view">
  <section>
    <div class="wrap">
      <div class="board-bar">
        <div><p class="eyebrow">Live Job Board</p><h2>Open RFQs</h2></div>
        <div class="filters" id="boardFilters"></div>
      </div>
      <div class="board" id="board"><p class="helper">Loading jobs…</p></div>
    </div>
  </section>
</main>

<main id="view-pros" class="view">
  <section>
    <div class="wrap">
      <p class="eyebrow">Directory</p>
      <h2>Verified contractors, with the work to prove it</h2>
      <p class="sub">Every profile shown here has cleared TradeBid's verification review: active LLC confirmed against the state registry, current insurance on file.</p>
      <div class="pros" id="pros"></div>
    </div>
  </section>
</main>

<main id="view-pricing" class="view">
  <section>
    <div class="wrap">
      <p class="eyebrow">Pricing</p>
      <h2>Free for homeowners. Flat for contractors.</h2>
      <p class="sub">No per-lead charges, no commission on the job. One subscription unlocks unlimited bidding in your trades and radius.</p>
      <div class="plans">
        <div class="plan">
          <h3>Homeowner</h3>
          <div class="price">$0<sub>/forever</sub></div>
          <ul><li>Unlimited RFQ posts</li><li>Unlimited competing bids</li><li>Verification badge shown on every bid</li><li>Direct hire — no platform commission</li></ul>
          <a class="btn btn-ghost btn-block" onclick="go('post')">Post a Job</a>
        </div>
        <div class="plan hot">
          <span class="flag">MOST POPULAR</span>
          <h3>Contractor Pro</h3>
          <div class="price">$89<sub>/month</sub></div>
          <ul><li>Full job board — scope, photos, budget</li><li>Unlimited bids, zero lead fees</li><li>2 trades · 75-mile radius</li><li>Public profile &amp; track record</li></ul>
          <a class="btn btn-brand btn-block" onclick="go('signup-contractor')">Start Verification</a>
        </div>
        <div class="plan">
          <h3>Contractor Crew</h3>
          <div class="price">$179<sub>/month</sub></div>
          <ul><li>Everything in Pro</li><li>Unlimited trades · statewide radius</li><li>3 estimator seats</li><li>Instant-alert on matching RFQs</li></ul>
          <a class="btn btn-ink btn-block" onclick="go('signup-contractor')">Start Verification</a>
        </div>
      </div>
    </div>
  </section>
</main>

<main id="view-signup" class="view">
  <section><div class="wrap authbox">
    <h2 class="center">Create your account</h2>
    <form class="card-form" onsubmit="return doSignup(event,'homeowner')">
      <label for="su-name">Name</label><input id="su-name" required maxlength="120" placeholder="First name is fine">
      <label for="su-email">Email</label><input id="su-email" type="email" required autocomplete="email" placeholder="you@example.com">
      <label for="su-pass">Password</label><input id="su-pass" type="password" required minlength="10" autocomplete="new-password" placeholder="At least 10 characters">
      <p class="helper">Posting jobs is always free.</p>
      <div class="form-foot"><p></p><button class="btn btn-brand" type="submit">Create Account</button></div>
      <div class="msg" id="signupMsg"></div>
    </form>
    <p class="swap">Signing up as a contractor? <button onclick="go('signup-contractor')">Get verified instead →</button></p>
    <p class="swap">Already have an account? <button onclick="go('login')">Log in</button></p>
  </div></section>
</main>

<main id="view-signup-contractor" class="view">
  <section><div class="wrap form-shell wide">
    <p class="eyebrow">Contractor Verification</p>
    <h2>Get your business verified</h2>
    <p class="sub">Required to list: an active LLC (or corporation) registered with your state, and a current Certificate of Insurance for general liability. Your subscription starts only after both are confirmed by a real reviewer.</p>

    <div id="contractorAccountStep">
      <div class="card-form">
        <legend>Step 1 — Create your account</legend>
        <form onsubmit="return doSignup(event,'contractor')">
          <label for="cu-name">Your name</label><input id="cu-name" required placeholder="Full name">
          <label for="cu-email">Business email</label><input id="cu-email" type="email" required autocomplete="email" placeholder="office@yourcompany.com">
          <label for="cu-pass">Password</label><input id="cu-pass" type="password" required minlength="10" autocomplete="new-password" placeholder="At least 10 characters">
          <div class="form-foot"><p></p><button class="btn btn-brand" type="submit">Create Account &amp; Continue</button></div>
          <div class="msg" id="cuMsg"></div>
        </form>
        <p class="swap">Already have a contractor account? <button onclick="go('login')">Log in</button></p>
      </div>
    </div>

    <div id="contractorVerifyStep" style="display:none">
      <div class="card-form">
        <legend>Step 2 — Business &amp; insurance details</legend>
        <p class="helper" id="verifyStatusLine"></p>
        <form id="verifyForm" onsubmit="return submitVerification(event)">
          <div class="grid-2">
            <div><label for="v-bizname">Legal business name</label><input id="v-bizname" required placeholder="Ridgeline Roofing LLC"></div>
            <div><label for="v-state">State of registration</label><input id="v-state" required placeholder="Tennessee"></div>
            <div><label for="v-num">LLC / entity control number</label><input id="v-num" required inputmode="numeric" placeholder="000123456"><p class="helper">Find this on your state's business search.</p></div>
            <div><label for="v-radius">Service radius (miles)</label><input id="v-radius" type="number" inputmode="numeric" min="5" max="500" value="75"></div>
          </div>
          <label>Primary trades</label>
          <div class="chips" id="verifyChips"></div>
          <label class="upload" for="v-coi">🛡 Upload Certificate of Insurance (PDF) — click to browse<input id="v-coi" type="file" accept="application/pdf"></label>
          <p class="helper" id="coiFileName"></p>
          <div class="form-foot">
            <p>We check your entity against your state's Secretary of State registry and read the COI before approving. Usually within one business day.</p>
            <button class="btn btn-brand" type="submit" id="verifySubmitBtn">Submit for Review</button>
          </div>
          <div class="msg" id="verifyMsg"></div>
        </form>
      </div>
    </div>
  </div></section>
</main>

<main id="view-login" class="view">
  <section><div class="wrap authbox">
    <h2 class="center">Log in</h2>
    <form class="card-form" onsubmit="return doLogin(event)">
      <label for="li-email">Email</label><input id="li-email" type="email" required autocomplete="email">
      <label for="li-pass">Password</label><input id="li-pass" type="password" required autocomplete="current-password">
      <div class="form-foot"><p></p><button class="btn btn-brand" type="submit">Log In</button></div>
      <div class="msg" id="loginMsg"></div>
    </form>
    <p class="swap">New here? <button onclick="go('signup')">Post a job free</button> · <button onclick="go('signup-contractor')">Get verified as a contractor</button></p>
  </div></section>
</main>

<main id="view-dashboard" class="view">
  <section><div class="wrap page">
    <p class="eyebrow">Contractor Account</p>
    <h2>Your verification status</h2>
    <div class="card-form" id="dashboardBody">Loading…</div>
  </div></section>
</main>

<main id="view-admin" class="view">
  <section><div class="wrap">
    <p class="eyebrow">Staff Only</p>
    <h2>Verification queue</h2>
    <p class="sub">Cross-check each business against the official state registry, open the COI, then approve or reject. Approving does not activate billing — do that from your Stripe dashboard once payment is confirmed (see backend README).</p>
    <div id="adminQueue"><p class="helper">Loading…</p></div>
  </div></section>
</main>

<main id="view-faq" class="view">
  <section><div class="wrap page">
    <p class="eyebrow">Support</p><h2>Frequently asked questions</h2>
    <details class="faq-item"><summary>Does TradeBid charge homeowners anything?</summary><div>No. Posting RFQs, receiving bids, and hiring are free. TradeBid earns revenue only from contractor subscriptions — never a commission on your project.</div></details>
    <details class="faq-item"><summary>How are contractors verified?</summary><div>Before a contractor can view or bid on jobs, a reviewer confirms their LLC or corporation is active on their state's Secretary of State business registry and checks a current Certificate of Insurance. We track policy expiration; lapsed coverage pauses the account automatically.</div></details>
    <details class="faq-item"><summary>Do contractors pay per lead?</summary><div>No. One flat monthly subscription unlocks unlimited bidding within chosen trades and radius. No per-lead charges, no commission on won jobs.</div></details>
    <details class="faq-item"><summary>Is my home address shown publicly?</summary><div>No. Open RFQs display only city and ZIP. Full address and contact details are shared only with the contractor whose bid you accept.</div></details>
    <details class="faq-item"><summary>Can I cancel my contractor subscription?</summary><div>Yes — subscriptions are month-to-month, cancel anytime; access continues through the end of the paid period.</div></details>
  </div></section>
</main>

<main id="view-terms" class="view">
  <section><div class="wrap page">
    <p class="eyebrow">Legal</p><h2>Terms of Service</h2>
    <div class="legal">
      <p class="updated">Last updated: [date] — have an attorney review before publishing</p>
      <h3>1. What TradeBid is</h3><p>TradeBid, LLC ("TradeBid," "we") operates a marketplace connecting homeowners posting Requests for Quote with independent contractors who subscribe to view and bid on them. TradeBid is not a contractor and is not a party to any agreement between a homeowner and a contractor.</p>
      <h3>2. Contractor verification</h3><p>Contractors must maintain an active LLC or corporation in good standing and a current general liability Certificate of Insurance on file. We may suspend accounts whose entity status or insurance lapses. Verification confirms documentation only; it is not an endorsement of work quality.</p>
      <h3>3. Bids and contracts</h3><p>Bids are estimates. Any contract, payment, warranty, or dispute related to the work is solely between homeowner and contractor.</p>
      <h3>4. Fees</h3><p>Contractor subscriptions bill monthly in advance and may be canceled anytime. TradeBid charges homeowners no fees and takes no commission.</p>
      <h3>5. Governing law</h3><p>Governed by the laws of the State of Tennessee. [Insert dispute-resolution clause per counsel.]</p>
    </div>
  </div></section>
</main>

<main id="view-privacy" class="view">
  <section><div class="wrap page">
    <p class="eyebrow">Legal</p><h2>Privacy Policy</h2>
    <div class="legal">
      <p class="updated">Last updated: [date] — have an attorney review before publishing</p>
      <h3>What we collect</h3><p>Homeowners: name, email, project details, city and ZIP. Contractors: business name, entity number, state of registration, insurance certificate, contact details, billing information (processed by our payment provider).</p>
      <h3>How we use it</h3><p>To operate the marketplace: publishing RFQs, verifying entity and insurance status, matching contractors, sending notifications, billing subscriptions.</p>
      <h3>What we share</h3><p>Your street address is shared only with a contractor whose bid you accept. We do not sell personal information.</p>
    </div>
  </div></section>
</main>

<main id="view-contact" class="view">
  <section><div class="wrap form-shell">
    <p class="eyebrow">Contact</p><h2>Talk to TradeBid</h2>
    <p class="sub">Questions about verification, billing, or a posting? We answer within one business day.</p>
    <form class="card-form" onsubmit="event.preventDefault(); this.style.display='none'; document.getElementById('contactSuccess').classList.add('show')">
      <label>Your name</label><input required>
      <label>Email</label><input type="email" required>
      <label>Message</label><textarea required></textarea>
      <div class="form-foot"><p>Or email support@[yourdomain].com directly.</p><button class="btn btn-brand" type="submit">Send Message</button></div>
    </form>
    <div class="msg ok" id="contactSuccess"><b>Message sent.</b> We'll reply within one business day.</div>
  </div></section>
</main>

<footer>
  <div class="wrap footer-grid">
    <div><button class="logo"><span class="mark"></span>TradeBid</button><p class="foot-blurb">The RFQ marketplace for residential trades. Free for homeowners. Flat-rate for verified contractors.</p></div>
    <div class="foot-col"><b>Marketplace</b><a onclick="go('post')">Post a Job</a><a onclick="go('board')">Find Work</a><a onclick="go('pros')">Directory</a><a onclick="go('pricing')">Pricing</a></div>
    <div class="foot-col"><b>Company</b><a onclick="go('faq')">FAQ</a><a onclick="go('contact')">Contact</a><a onclick="go('signup-contractor')">Verification</a></div>
    <div class="foot-col"><b>Legal</b><a onclick="go('terms')">Terms</a><a onclick="go('privacy')">Privacy</a></div>
  </div>
  <div class="wrap foot-base">
    <span style="font-family:var(--mono);font-size:11px">© 2026 TRADEBID, LLC</span>
    <span style="font-family:var(--mono);font-size:11px">EVERY LISTED CONTRACTOR: ACTIVE LLC + COI ON FILE</span>
  </div>
</footer>

<script src="/app.js" defer></script>
</body>
</html>
