// One-time setup: create your first admin (staff) account.
// Run with:  node scripts/seed-admin.js you@yourcompany.com "a-strong-password" "Your Name"
require('dotenv').config();
const bcrypt = require('bcryptjs');
const { db } = require('../db');

const [,, email, password, name] = process.argv;
if (!email || !password || !name) {
  console.log('Usage: node scripts/seed-admin.js <email> <password> "<name>"');
  process.exit(1);
}
if (password.length < 10) {
  console.log('Password must be at least 10 characters.');
  process.exit(1);
}

const existing = db.prepare('SELECT id FROM users WHERE email = ?').get(email.toLowerCase());
if (existing) {
  db.prepare("UPDATE users SET role = 'admin' WHERE id = ?").run(existing.id);
  console.log(`Existing user ${email} promoted to admin.`);
} else {
  const hash = bcrypt.hashSync(password, 12);
  db.prepare(
    'INSERT INTO users (email, password_hash, role, name) VALUES (?, ?, ?, ?)'
  ).run(email.toLowerCase(), hash, 'admin', name);
  console.log(`Admin account created for ${email}.`);
}
